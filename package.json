{
  "name": "smart-study",
  "version": "1.0.0",
  "description": "Smart Study BD — Android WebView App",
  "private": true,
  "scripts": {
    "build": "bash scripts/build.sh",
    "build:watch": "nodemon --watch app/src/main/assets/js --ext js --exec 'bash scripts/build.sh'",
