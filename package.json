    "clean": "rm -f app/src/main/assets/js/bundle*.js"
  },
  "devDependencies": {
    "terser": "^5.31.0",
    "javascript-obfuscator": "^4.1.1"
  },
  "engines": {
    "node": ">=18"
  }
}
