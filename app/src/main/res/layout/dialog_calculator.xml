<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/rounded_dialog_bg">

    <!-- Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calculator"
            android:textColor="#AAFFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/tv_calc_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:gravity="end"
            android:layout_marginTop="4dp"
            android:minLines="1" />
    </LinearLayout>

    <!-- Buttons grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:padding="8dp">

        <!-- Row 1: C, ←, ÷, × -->
        <Button android:id="@+id/btn_clear"     android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="C"  android:textSize="16sp" android:backgroundTint="#F5F5F5" android:textColor="@color/red_due" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_backspace" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="⌫" android:textSize="16sp" android:backgroundTint="#F5F5F5" android:textColor="@color/primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_divide"    android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="÷" android:textSize="20sp" android:backgroundTint="@color/primary_light" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_multiply"  android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="×" android:textSize="20sp" android:backgroundTint="@color/primary_light" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- Row 2: 7, 8, 9, - -->
        <Button android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="7" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="8" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="9" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_minus" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="−" android:textSize="20sp" android:backgroundTint="@color/primary_light" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- Row 3: 4, 5, 6, + -->
        <Button android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="4" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="5" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="6" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_plus" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="+" android:textSize="20sp" android:backgroundTint="@color/primary_light" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- Row 4: 1, 2, 3, = -->
        <Button android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="1" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="2" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="3" android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_equals" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="=" android:textSize="22sp" android:backgroundTint="@color/primary" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

        <!-- Row 5: 0, ., USE, CLOSE -->
        <Button android:id="@+id/btn_0"   android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="0"   android:textSize="18sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_dot" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="."   android:textSize="22sp" android:backgroundTint="#FAFAFA" android:textColor="@color/text_primary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_use" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="USE"  android:textSize="13sp" android:backgroundTint="@color/green_settled" android:textColor="@color/white" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        <Button android:id="@+id/btn_close" android:layout_width="0dp" android:layout_height="56dp" android:layout_columnWeight="1" android:text="✕"  android:textSize="18sp" android:backgroundTint="#EEEEEE" android:textColor="@color/text_secondary" android:layout_margin="3dp" style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />

    </GridLayout>

</LinearLayout>
